# =========================================
# CÀI ĐẶT - Sao chép file này thành .env
# và điền thông tin của bạn vào
# =========================================

# --- FACEBOOK MESSENGER ---
# Lấy từ: developers.facebook.com > App > Messenger > Page Access Token
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Tự đặt chuỗi bất kỳ (ví dụ: mysecret123)
# Dùng để xác minh webhook với Facebook
VERIFY_TOKEN=mysecrettoken123

# Lấy từ: developers.facebook.com > App Settings > Basic > App Secret
APP_SECRET=your_app_secret_here

# --- GROK AI ---
# Lấy từ: console.x.ai
GROK_API_KEY=xai-your-key-here

# Model AI (grok-3-mini = nhanh & rẻ, grok-3 = thông minh hơn)
GROK_MODEL=grok-3-mini

# --- SERVER ---
PORT=3000
